# Core Application Settings
# DEBUG defaults to False in settings.py. Set to True only during local development.
DEBUG=False
SECRET_KEY=your-strong-random-secret-key-here
JWT_SIGNING_KEY=your-different-strong-random-jwt-signing-key-here

# Database Configuration (PostgreSQL only - required)
DATABASE_URL=postgresql://db_user:db_password@db_host:5432/db_name?sslmode=require

# Frontend & Security Hosts / Origins
FRONTEND_URL=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# HTTPS & Security Overrides (optional, defaults automatically configured based on DEBUG status)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Throttling Configuration
THROTTLE_ANON_RATE=60/minute
THROTTLE_USER_RATE=1000/minute

# Upload & Request Size Limits (in bytes, default: 10MB)
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000

# Cloudinary Configuration (Optional - if left empty, automatically falls back to local FileSystemStorage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@clinicmanagement.com
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=24
